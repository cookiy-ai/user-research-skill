{
  "name": "cookiy-mcp",
  "version": "1.7.8",
  "description": "One-command bootstrap for Cookiy local skills and MCP connections in your AI coding clients",
  "homepage": "https://cookiy.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cookiy-ai/cookiy-skill.git"
  },
  "bugs": {
    "url": "https://github.com/cookiy-ai/cookiy-skill/issues"
  },
  "type": "module",
  "bin": {
    "cookiy-mcp": "bin/cli.mjs"
  },
  "files": [
    "bin/",
    "lib/",
    "skill-assets/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs test/clients/*.test.mjs test/skills/*.test.mjs",
    "build:bundle": "node ./scripts/build-bundle.mjs",
    "build:macos": "node ./scripts/build-macos-binary.mjs",
    "build:brew-formula": "node ./scripts/generate-homebrew-formula.mjs"
  },
  "keywords": [
    "cookiy",
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "skill",
    "user-research",
    "interview",
    "voice",
    "claude",
    "cursor",
    "vscode",
    "codex",
    "manus",
    "windsurf",
    "cline",
    "openclaw",
    "setup"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.27.2",
    "postject": "^1.0.0-alpha.6"
  }
}
